---
interface Props {
  anchorDate: string; // YYYY-MM-DD – the date used to compute the current week
}
const { anchorDate } = Astro.props;
---

<div id="week-picker" class="flex items-center gap-2 sm:gap-3 px-4 py-3 rounded-xl bg-gray-900/60 border border-gray-800 mb-8 flex-wrap">

  <!-- Prev week -->
  <button id="wp-prev" aria-label="Previous week"
    class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <!-- Date input + week label -->
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <input
      type="date"
      id="wp-input"
      value={anchorDate}
      class="bg-gray-800 border border-gray-700 text-gray-200 text-sm rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent scheme-dark shrink-0"
    />
    <span id="wp-label" class="text-sm text-gray-500 hidden sm:block truncate"></span>
  </div>

  <!-- Today -->
  <button id="wp-today"
    class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-indigo-500/20 text-indigo-300 border border-indigo-500/30 hover:bg-indigo-500/30 transition-colors shrink-0">
    Today
  </button>

  <!-- Next week -->
  <button id="wp-next" aria-label="Next week"
    class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </button>

</div>

<script>
  function toLocalISO(d: Date): string {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function getMondayOfWeek(dateStr: string): string {
    const d = new Date(dateStr + 'T00:00:00');
    const day = d.getDay();
    const monday = new Date(d);
    monday.setDate(d.getDate() - (day === 0 ? 6 : day - 1));
    return toLocalISO(monday);
  }

  function addDays(dateStr: string, days: number): string {
    const d = new Date(dateStr + 'T00:00:00');
    d.setDate(d.getDate() + days);
    return toLocalISO(d);
  }

  function navigate(dateStr: string): void {
    const url = new URL(window.location.href);
    url.searchParams.set('date', dateStr);
    window.location.href = url.toString();
  }

  function updateLabel(dateStr: string): void {
    const label = document.getElementById('wp-label');
    if (!label) return;
    const monday = getMondayOfWeek(dateStr);
    const friday = addDays(monday, 4);
    const m = new Date(monday + 'T00:00:00');
    const f = new Date(friday + 'T00:00:00');
    label.textContent = `${m.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })} – ${f.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
  }

  const input = document.getElementById('wp-input') as HTMLInputElement | null;
  if (input) {
    updateLabel(input.value);
    input.addEventListener('change', () => navigate(input.value));
  }

  document.getElementById('wp-prev')?.addEventListener('click', () => {
    if (input) navigate(addDays(input.value, -7));
  });
  document.getElementById('wp-next')?.addEventListener('click', () => {
    if (input) navigate(addDays(input.value, 7));
  });
  document.getElementById('wp-today')?.addEventListener('click', () => {
    navigate(toLocalISO(new Date()));
  });
</script>
